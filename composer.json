{
    "name": "opensubtitles/cf-llm-srt-translator",
    "description": "Cloudflare Workers AI SRT subtitle translator",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "vlucas/phpdotenv": "^5.6",
        "mantas-done/subtitles": "*",
        "whitecube/lingua": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "CloudflareSrt\\": "src/"
        }
    },
    "scripts": {
        "build": "php -dphar.readonly=0 $(composer config home)/vendor/bin/box compile"
    }
}
